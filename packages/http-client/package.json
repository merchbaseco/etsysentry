{
  "name": "@etsysentry/http-client",
  "version": "0.6.0",
  "description": "Typed tRPC client for EtsySentry public APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tanstack/react-query": "5.90.21",
    "@trpc/client": "11.10.0",
    "@trpc/tanstack-react-query": "11.10.0"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "typescript": "5.9.3"
  }
}
