# Server runtime
NODE_ENV=development
PORT=8080
APP_ORIGIN=http://localhost:5173
# Set true to disable pg-boss workers in this process.
DISABLE_SERVER_JOB_RUNNER=false

# npm publishing
NPM_TOKEN=your_npm_token

# CLI runtime (optional)
ES_API_KEY=your_etsysentry_api_key
ES_BASE_URL=https://etsysentry.merchbase.co
ES_STORAGE_DIR=/data/etsysentry

# Clerk auth
CLERK_SECRET_KEY=your_clerk_secret_key
ADMIN_EMAIL=admin@example.com

# Etsy OAuth (OAuth 2.0 + PKCE)
# Create these in Etsy Developer Apps.
ETSY_API_KEY=your_etsy_keystring
ETSY_API_SHARED_SECRET=your_etsy_shared_secret
# Use your server's public callback URL in production.
# Local example: http://localhost:8080/auth/etsy/callback
# Production example: https://etsysentry.merchbase.co/auth/etsy/callback
ETSY_OAUTH_REDIRECT_URI=http://localhost:8080/auth/etsy/callback
ETSY_OAUTH_SCOPES='listings_r listings_w shops_r transactions_r'

# OAuth flow internals
ETSY_OAUTH_STATE_TTL_MS=600000
ETSY_OAUTH_REFRESH_SKEW_MS=120000

# Etsy API rate limiting / retry behavior
# Defaults match Etsy's documented header examples and auto-adjust from response headers.
ETSY_RATE_LIMIT_DEFAULT_PER_SECOND=150
ETSY_RATE_LIMIT_DEFAULT_PER_DAY=100000
ETSY_RATE_LIMIT_MAX_RETRIES=5
ETSY_RATE_LIMIT_BACKOFF_INITIAL_MS=1000
ETSY_RATE_LIMIT_BACKOFF_MAX_MS=60000
ETSY_API_REQUEST_TIMEOUT_MS=30000

# Website runtime (optional)
# Use when the dashboard is not served behind the same origin as `/api`.
VITE_SERVER_ORIGIN=
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Database runtime (RankWrangler-style)
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_NAME=etsysentry
DATABASE_USER=etsysentry
DATABASE_PASSWORD=replace_me

# Docker/Postgres hosting (mac-mini)
ETSYSENTRY_DATABASE_NAME=etsysentry
ETSYSENTRY_DATABASE_USER=etsysentry
ETSYSENTRY_DATABASE_PASSWORD=replace_me
