{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["bun-types", "node"],
        "verbatimModuleSyntax": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src"]
}
