{
    "name": "@etsysentry/server",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "bun build ./src/index.ts --target bun --outdir ./dist",
        "start": "bun run ./dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "ADMIN_EMAIL=admin@example.com CLERK_SECRET_KEY=test ETSY_API_KEY=test ETSY_API_SHARED_SECRET=test ETSY_OAUTH_REDIRECT_URI=http://localhost:8080/auth/etsy/callback bun test",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun run ./src/db/migrate-runner.ts"
    },
    "dependencies": {
        "@clerk/backend": "^2.32.0",
        "@fastify/cors": "^11.1.0",
        "@trpc/server": "^11.7.1",
        "drizzle-orm": "^0.44.6",
        "fastify": "^5.6.0",
        "postgres": "^3.4.7",
        "zod": "^4.1.11"
    },
    "devDependencies": {
        "@types/node": "^24.5.2",
        "bun-types": "^1.3.5",
        "drizzle-kit": "^0.31.5",
        "typescript": "^5.9.2"
    }
}
