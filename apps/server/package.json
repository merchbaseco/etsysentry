{
    "name": "@etsysentry/server",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "DISABLE_SERVER_JOB_RUNNER=true bun --watch src/index.ts",
        "build": "bun build ./src/index.ts --target bun --outdir ./dist",
        "start": "DISABLE_SERVER_JOB_RUNNER=false bun run ./dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "ADMIN_EMAIL=admin@example.com CLERK_SECRET_KEY=test ETSY_API_KEY=test ETSY_API_SHARED_SECRET=test ETSY_OAUTH_REDIRECT_URI=http://localhost:8080/auth/etsy/callback bun test",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun run ./src/db/migrate-runner.ts"
    },
    "dependencies": {
        "@clerk/backend": "2.33.3",
        "@fastify/cors": "11.2.0",
        "@trpc/server": "11.10.0",
        "drizzle-orm": "0.45.2",
        "fastify": "5.8.5",
        "pg-boss": "12.13.0",
        "postgres": "3.4.8",
        "ws": "8.20.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@types/node": "24.10.13",
        "@types/ws": "8.18.1",
        "bun-types": "1.3.9",
        "drizzle-kit": "0.31.10",
        "typescript": "5.9.3"
    }
}
