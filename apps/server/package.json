{
    "name": "@etsysentry/server",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "bun build ./src/index.ts --target bun --outdir ./dist",
        "start": "bun run ./dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "ETSY_API_KEY=test ETSY_OAUTH_REDIRECT_URI=http://localhost:8080/auth/etsy/callback bun test"
    },
    "dependencies": {
        "@fastify/cors": "^11.1.0",
        "@trpc/server": "^11.7.1",
        "fastify": "^5.6.0",
        "zod": "^4.1.11"
    },
    "devDependencies": {
        "bun-types": "^1.3.5",
        "@types/node": "^24.5.2",
        "typescript": "^5.9.2"
    }
}
